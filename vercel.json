{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "yonastore.neocharge.app"
        }
      ],
      "destination": "https://novasplay.neocharge.app/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
